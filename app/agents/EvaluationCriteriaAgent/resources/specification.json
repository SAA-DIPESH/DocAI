                "Maximum",
                "Description",
                "SourceEvidence"
              ],
              "properties": {
                "Minimum": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "Maximum": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "Description": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "SourceEvidence": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/SourceEvidence"
                  }
                }
              }
            },
            "PriceScoringFormula": {
              "type": [
                "string",
                "null"
              ]
            },
            "SourceEvidence": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/SourceEvidence"
              }
            }
          }
        },
        "Criteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Criterion"
          }
        },
        "MandatoryConditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Condition"
          }
        },
        "Conflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Conflict"
          }
        },
        "MissingInformation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MissingInformation"
          }
        },
        "Validation": {
          "$ref": "#/$defs/Validation"
        },
        "ReviewFlags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ReviewFlag"
          }
        },
        "RequiresHumanReview": {
          "type": "boolean"
        },
        "SourceDocuments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "DocumentId",
              "DocumentName"
            ],
            "properties": {
              "DocumentId": {
                "type": "string"
              },
              "DocumentName": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      },
      "$defs": {
        "SourceEvidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "DocumentId",
            "ChunkId",
            "PageID",
            "PageNumber",
            "ChunkIndex",
            "EvidenceExcerpt",
            "SupportedFields"
          ],
          "properties": {
            "DocumentId": {
              "type": "string"
            },
            "ChunkId": {
              "type": "string"
            },
            "PageID": {
              "type": [
                "string",
                "null"
              ]
            },
            "PageNumber": {
              "type": [
                "integer",
                "null"
              ]
            },
            "ChunkIndex": {
              "type": [
                "integer",
                "null"
              ]
            },
            "EvidenceExcerpt": {
              "type": "string",
              "minLength": 1
            },
            "SupportedFields": {
              "type": "array",
              "minItems": 1,
