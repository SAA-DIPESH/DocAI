              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "WeightPercent": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 100
            },
            "MaximumScore": {
              "type": [
                "number",
                "null"
              ]
            },
            "MinimumScore": {
              "type": [
                "number",
                "null"
              ]
            },
            "MinimumPercent": {
              "type": [
