        },
        "Validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "SourceCoverage",
            "NumericValidity",
            "OverallWeightingReconciliation",
            "ParentChildReconciliation",
            "PassFailSeparation",
            "SupersessionControl",
            "MissingDataDiscipline"
          ],
          "properties": {
            "SourceCoverage": {
              "$ref": "#/$defs/ValidationCheck"
            },
            "NumericValidity": {
              "$ref": "#/$defs/ValidationCheck"
            },
            "OverallWeightingReconciliation": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "Status",
                "CalculatedTotalPercent",
                "ExpectedTotalPercent",
                "Explanation"
              ],
              "properties": {
                "Status": {
                  "enum": [
                    "VALID",
                    "INVALID",
                    "NOT_ASSESSABLE",
                    "NOT_APPLICABLE"
                  ]
                },
                "CalculatedTotalPercent": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "ExpectedTotalPercent": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "Explanation": {
                  "type": "string"
                }
              }
            },
            "ParentChildReconciliation": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "ParentCriterionId",
                  "Status",
                  "ParentWeightPercent",
                  "ChildTotalWeightPercent",
                  "Explanation"
                ],
                "properties": {
                  "ParentCriterionId": {
                    "type": "string"
                  },
                  "Status": {
                    "enum": [
                      "VALID",
                      "INVALID",
                      "NOT_ASSESSABLE",
                      "NOT_APPLICABLE"
                    ]
                  },
                  "ParentWeightPercent": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "ChildTotalWeightPercent": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "Explanation": {
                    "type": "string"
                  }
                }
              }
            },
            "PassFailSeparation": {
              "$ref": "#/$defs/ValidationCheck"
            },
            "SupersessionControl": {
              "$ref": "#/$defs/ValidationCheck"
            },
            "MissingDataDiscipline": {
              "$ref": "#/$defs/ValidationCheck"
            }
          }
        },
        "ValidationCheck": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "Status",
            "Explanation"
          ],
          "properties": {
            "Status": {
              "enum": [
                "VALID",
                "INVALID",
                "NOT_ASSESSABLE",
                "NOT_APPLICABLE"
              ]
            },
            "Explanation": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "mandatory_validation_rules": {
    "source_coverage": "No item in Criteria or MandatoryConditions may have an empty SourceEvidence array.",
    "numeric_validity": "All populated percentage fields must be numeric and between 0 and 100 inclusive.",
    "overall_weightings": "Calculate a total only when the evidence identifies a complete overall evaluation allocation. Never assume an omitted allocation is zero.",
    "parent_child_weightings": "Compare parent and child totals only when both the parent value and a complete child set are explicitly available.",
    "pass_fail_separation": "Never represent a pass/fail or mandatory item solely as a weighted criterion unless the evidence explicitly states both roles.",
    "supersession": "Only mark an earlier value superseded when the text explicitly establishes the replacement relationship.",
    "missing_values": "Use null for unsupported fields and include a MissingInformation item where the gap is material."
  },
  "not_found_contract": {
    "EvaluationModelDetected": false,
    "ExtractionStatus": "NOT_FOUND",
    "Criteria": [],
    "MandatoryConditions": [],
    "Conflicts": [],
    "MissingInformation": [
      {
        "Field": "EvaluationCriteria",
        "Reason": "No explicit evaluation, award, weighting, scoring, threshold, pass/fail, or price-scoring evidence was found in the supplied evidence chunks.",
        "RelatedCriterionId": null,
        "SourceEvidence": []
      }
    ],
    "RequiresHumanReview": false
  }
}
