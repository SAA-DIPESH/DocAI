                "null"
              ],
              "minimum": 0,
              "maximum": 100
            },
            "PassFail": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "Mandatory": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "Description": {
              "type": [
                "string",
                "null"
              ]
            },
            "PriceScoringFormula": {
              "type": [
                "string",
                "null"
              ]
            },
            "SourceEvidence": {
              "type": "array",
