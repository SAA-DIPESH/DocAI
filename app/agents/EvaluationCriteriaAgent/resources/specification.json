{
  "schema_version": "1.0",
  "artifact": "Evaluation Criteria Extraction Agent Specification",
  "purpose": "Define the input contract, processing contract, output contract and deterministic validation expectations for grounded extraction of tender evaluation criteria.",
  "input_contract": {
    "required": [
      "TenderContext",
      "EvidenceChunks"
    ],
    "TenderContext": {
      "CompanyId": "string | null",
      "TenderId": "string",
      "RetrievalProfileId": "string | null"
    },
    "EvidenceChunks": {
      "type": "array",
      "minItems": 0,
      "item_contract": {
        "canonical_fields": {
          "DocumentId": "string",
          "ChunkId": "string",
          "DocumentName": "string | null",
          "DocumentType": "string | null",
          "PageID": "string | null",
          "PageNumber": "integer | null",
          "ChunkIndex": "integer | null",
          "RelatedSection": "string | null",
          "TableId": "string | null",
          "TableCaption": "string | null",
          "TableHeaders": "array | null",
          "TableJson": "object | null",
          "Text": "string"
        },
        "accepted_source_field_aliases": {
          "DocumentId": [
            "DocumentId",
            "document_id"
          ],
          "ChunkId": [
            "ChunkId",
            "chunk_id"
          ],
          "DocumentName": [
            "DocumentName",
            "document_name"
          ],
          "DocumentType": [
            "DocumentType",
            "document_type"
          ],
          "PageID": [
            "PageID",
            "page_id"
          ],
          "PageNumber": [
            "PageNumber",
            "page_number"
          ],
          "ChunkIndex": [
            "ChunkIndex",
            "chunk_index"
          ],
          "RelatedSection": [
            "RelatedSection",
            "related_section",
            "section_heading"
          ],
          "TableId": [
            "TableId",
            "table_id"
          ],
          "TableCaption": [
            "TableCaption",
            "table_caption"
          ],
          "TableHeaders": [
            "TableHeaders",
            "table_headers"
          ],
          "TableJson": [
            "TableJson",
            "table_json"
          ],
          "Text": [
            "Text",
            "text"
          ]
        },
        "notes": [
          "The normalisation layer must preserve the original payload for traceability.",
          "ChunkIndex and PageID support retrieval context; they are not evidence of an evaluation rule.",
          "Text is the only field from which substantive evaluation facts may be extracted, except that table metadata may establish the meaning of a table cell."
        ]
      }
    }
  },
  "processing_contract": [
    {
      "step": 1,
      "name": "Normalise evidence fields",
      "rule": "Map aliases to canonical field names without deleting source text or metadata."
    },
    {
      "step": 2,
      "name": "Detect evaluation evidence",
      "rule": "Identify explicit award methodology, weighted criteria, sub-criteria, scoring scales, thresholds, pass/fail gates, mandatory conditions, commercial scoring rules, evaluation stages, and explicit supersession statements."
    },
    {
      "step": 3,
      "name": "Interpret table context",
      "rule": "Use supplied table headers, captions, parent rows, footnotes and neighbour chunks before assigning meaning to a number."
    },
    {
      "step": 4,
      "name": "Extract facts",
      "rule": "Populate a field only when explicitly supported; otherwise populate null and add a gap, conflict or review flag."
    },
    {
      "step": 5,
      "name": "Attach evidence",
      "rule": "Attach field-level source evidence to every extracted record and every overall scoring value."
    },
    {
      "step": 6,
      "name": "Resolve explicit supersession",
      "rule": "Replace an earlier value only where evidence explicitly says it supersedes, replaces, amends or changes that exact earlier value."
    },
    {
      "step": 7,
      "name": "Run deterministic validations",
      "rule": "Validate numeric bounds, complete overall weight total where explicitly complete, parent/child totals where explicitly complete, source coverage, separation of pass/fail from weighted criteria, and conflicts."
    }
  ],
  "controlled_vocabularies": {
    "ExtractionStatus": [
      "COMPLETED",
      "PARTIAL",
      "NOT_FOUND",
      "NEEDS_REVIEW"
    ],
    "PrimaryCategory": [
      "WEIGHTED_CRITERION",
      "SUBCRITERION",
      "PASS_FAIL_GATE",
      "MANDATORY_REQUIREMENT",
      "MINIMUM_THRESHOLD",
      "COMMERCIAL_SCORING_RULE",
      "EVALUATION_STAGE",
      "SUBMISSION_REQUIREMENT",
      "INFORMATIONAL"
    ],
    "ValidationStatus": [
      "VALID",
      "INVALID",
      "NOT_ASSESSABLE",
      "NOT_APPLICABLE"
    ],
    "ConflictStatus": [
      "OPEN",
      "EXPLICITLY_SUPERSEDED",
      "RESOLVED_BY_HUMAN"
    ],
    "ReviewFlagType": [
      "MISSING_SOURCE_EVIDENCE",
      "AMBIGUOUS_OCR",
      "INCOMPLETE_TABLE_CONTEXT",
      "MISSING_REFERENCED_SECTION",
      "CONFLICTING_VALUES",
      "INVALID_WEIGHT_TOTAL",
      "INVALID_PARENT_CHILD_TOTAL",
      "TRUNCATED_TEXT",
      "UNCLEAR_NUMERIC_MEANING",
      "EXPLICIT_SUPERSESSION_UNCLEAR"
    ]
  },
  "output_contract": {
    "required_top_level_fields": [
      "SchemaVersion",
      "CompanyId",
      "TenderId",
      "EvaluationModelDetected",
      "ExtractionStatus",
      "OverallScoring",
      "Criteria",
      "MandatoryConditions",
      "Conflicts",
      "MissingInformation",
      "Validation",
      "ReviewFlags",
      "RequiresHumanReview",
      "SourceDocuments"
    ],
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "SchemaVersion",
        "CompanyId",
        "TenderId",
        "EvaluationModelDetected",
        "ExtractionStatus",
        "OverallScoring",
        "Criteria",
        "MandatoryConditions",
        "Conflicts",
        "MissingInformation",
        "Validation",
        "ReviewFlags",
        "RequiresHumanReview",
        "SourceDocuments"
      ],
      "properties": {
        "SchemaVersion": {
          "const": "1.0"
        },
        "CompanyId": {
          "type": [
            "string",
            "null"
          ]
        },
        "TenderId": {
          "type": "string"
        },
        "EvaluationModelDetected": {
          "type": "boolean"
        },
        "ExtractionStatus": {
          "enum": [
            "COMPLETED",
            "PARTIAL",
            "NOT_FOUND",
            "NEEDS_REVIEW"
          ]
        },
        "OverallScoring": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "AwardMethod",
            "QualityWeightPercent",
            "PriceWeightPercent",
            "OtherOverallWeightings",
            "ScoringScale",
            "PriceScoringFormula",
            "SourceEvidence"
          ],
          "properties": {
