              "type": "array",
              "items": {
                "$ref": "#/$defs/SourceEvidence"
              }
            }
          }
        },
        "Criterion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "CriterionId",
            "Name",
            "PrimaryCategory",
            "SecondaryCategories",
            "ParentCriterionId",
            "QuestionReferences",
            "WeightPercent",
            "MaximumScore",
            "MinimumScore",
            "MinimumPercent",
            "PassFail",
            "Mandatory",
            "Description",
            "PriceScoringFormula",
            "SourceEvidence"
          ],
          "properties": {
            "CriterionId": {
