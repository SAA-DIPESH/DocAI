                "MISSING_REFERENCED_SECTION",
                "CONFLICTING_VALUES",
                "INVALID_WEIGHT_TOTAL",
                "INVALID_PARENT_CHILD_TOTAL",
                "TRUNCATED_TEXT",
                "UNCLEAR_NUMERIC_MEANING",
                "EXPLICIT_SUPERSESSION_UNCLEAR"
              ]
            },
