              "type": [
                "string",
                "null"
              ]
            },
            "QualityWeightPercent": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 100
            },
            "PriceWeightPercent": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 100
            },
            "OtherOverallWeightings": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/WeightingItem"
              }
            },
            "ScoringScale": {
              "type": "object",
