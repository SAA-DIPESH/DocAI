  "evidence_payload_fields_to_return": [
    "tenant_id",
    "tender_id",
    "document_id",
    "document_name",
    "document_type",
    "document_version",
    "is_latest_document_version",
    "page_number",
    "page_end_number",
    "chunk_id",
    "chunk_index",
    "chunk_type",
    "section_heading",
    "section_heading_normalised",
    "parent_section_id",
    "table_id",
    "table_caption",
    "table_headers",
    "table_row_index",
    "table_json",
    "text",
    "source_file_url",
    "ocr_confidence",
    "parse_status",
    "created_at"
  ],
  "post_retrieval_rules": {
    "group_by": [
      "document_id",
      "section_heading",
      "table_id"
    ],
    "retain_at_least_one_result_per_high_relevance_document": true,
    "prefer_latest_document_version": true,
    "detect_conflicting_values": true,
    "conflict_fields": [
      "quality_weight_percent",
      "price_weight_percent",
      "scoring_scale",
      "minimum_score",
      "weight_percent",
      "price_scoring_formula"
    ],
    "send_to_llm_only_when_source_evidence_exists": true,
    "return_not_found_when_no_grounded_evidence_exists": true
  },
  "qdrant_payload_schema": {
    "description": "Actual Qdrant payload field names used by the paired Python retriever. ChunkIndex and PageID are mandatory for reliable context expansion.",
    "field_mapping": {
      "company_id": "CompanyId",
      "tender_id": "TenderId",
      "document_id": "DocumentId",
      "chunk_id": "ChunkId",
      "document_name": "DocumentName",
      "text": "Text",
      "document_type": "DocumentType",
      "created_at": "CreatedAt",
