{
  "profile_id": "EVALUATION_CRITERIA_RETRIEVAL_V2",
  "profile_name": "Tender Evaluation Criteria Retrieval – Qdrant Payload Schema V2",
  "agent_name": "EvaluationCriteriaExtractionAgent",
  "description": "Retrieves all evidence required to identify weighted criteria, scoring methodology, pass/fail gates, thresholds, commercial scoring and award methodology from tender documents.",
  "runtime_placeholders": {
    "tenant_id": "{{tenant_id}}",
    "company_id": "{{company_id}}",
    "tender_id": "{{tender_id}}",
    "collection_name": "{{tender_chunks_collection}}"
  },
  "retrieval_strategy": {
    "mode": "hybrid",
    "dense_vector_name": "content_dense",
    "sparse_vector_name": "content_sparse",
    "fusion_method": "rrf",
    "run_anchor_groups_in_parallel": true,
    "candidate_limit_per_query_variant": 15,
    "maximum_candidates_per_anchor": 30,
    "maximum_total_candidates_before_deduplication": 180,
    "maximum_evidence_clusters_for_llm": 35,
    "deduplication": {
      "enabled": true,
      "primary_key": [
        "document_id",
        "chunk_id"
      ],
      "near_duplicate_text_similarity_threshold": 0.94,
      "retain_highest_ranked_duplicate": true
    },
    "reranking": {
      "enabled": true,
      "rerank_top_n": 80,
      "prefer_chunk_types": [
        "table",
        "table_row",
        "section",
        "paragraph",
        "appendix"
      ],
      "boost_rules": [
        {
          "field": "chunk_type",
          "value": "table",
          "boost": 0.25
        },
        {
          "field": "chunk_type",
          "value": "table_row",
          "boost": 0.2
        },
        {
          "field": "section_heading_normalised",
          "contains_any": [
            "evaluation",
            "award",
            "scoring",
            "weighting",
            "quality",
            "price",
            "commercial"
          ],
          "boost": 0.2
        },
        {
          "field": "document_type",
          "contains_any": [
            "EvaluationMethodology",
            "AwardCriteria",
            "InstructionsToTenderers",
            "InvitationToTender",
            "PricingSchedule",
            "ResponseQuestionnaire",
            "Clarification",
            "Addendum"
          ],
          "boost": 0.15
        },
        {
          "field": "is_table_header_or_caption",
          "value": true,
          "boost": 0.1
        }
      ]
    },
    "max_query_workers": 8
  },
  "mandatory_qdrant_filter": {
    "must": [
      {
        "key": "CompanyId",
        "match": {
          "value": "{{company_id}}"
        }
      },
      {
        "key": "TenderId",
        "match": {
          "value": "{{tender_id}}"
        }
      }
    ],
    "must_not": []
  },
  "preferred_document_types": [
    "EvaluationMethodology",
    "AwardCriteria",
    "InstructionsToTenderers",
    "InvitationToTender",
    "TenderSpecification",
    "ResponseQuestionnaire",
    "PricingSchedule",
    "CommercialSchedule",
    "Clarification",
    "Addendum",
    "Appendix",
    "TermsAndConditions"
  ],
  "context_expansion": {
    "enabled": true,
    "neighbour_chunks_before": 2,
    "neighbour_chunks_after": 2,
    "include_same_section": true,
    "include_parent_section": true,
    "include_table_header": true,
    "include_full_table_when_match_is_table_row": true,
    "include_table_caption": true,
    "include_same_page_chunks": true,
    "include_previous_page_when_heading_continues": true,
    "include_next_page_when_table_continues": true,
    "chunk_index_is_monotonic_within_document": true,
    "page_id_is_shared_by_all_chunks_on_source_page": true,
    "same_page_chunk_cap": 80,
    "whole_document_fallback_cap": 250
  },
  "anchor_groups": [
    {
      "anchor_id": "EC_AWARD_EVALUATION_OVERVIEW",
      "priority": 1,
      "objective": "Find the buyer's overall evaluation and award methodology, including the procurement award basis and high-level quality versus price model.",
      "anchor_query": "Tender evaluation criteria award methodology quality price weighting scoring model most economically advantageous tender.",
      "query_variants": [
        "evaluation criteria and award methodology",
        "award criteria quality price weighting",
        "tender evaluation process and scoring methodology",
        "most economically advantageous tender evaluation",
        "quality and commercial evaluation model",
        "how tenders will be evaluated and awarded",
        "evaluation framework and award decision"
      ],
      "lexical_keywords": [
        "evaluation criteria",
        "award criteria",
        "award methodology",
        "evaluation methodology",
        "evaluation process",
        "evaluation model",
        "evaluation framework",
        "quality price",
        "quality/price",
        "MEAT",
        "most economically advantageous tender",
        "most advantageous tender",
        "tender award"
      ],
      "section_heading_hints": [
        "evaluation and award criteria",
        "evaluation methodology",
        "award criteria",
        "tender evaluation",
        "basis of award",
        "evaluation process",
        "award decision"
      ],
      "expected_evidence": [
        "award_method",
        "quality_weight_percent",
        "price_weight_percent",
        "overall_scoring_model",
        "evaluation_stages"
      ]
    },
