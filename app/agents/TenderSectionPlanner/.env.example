MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=DocAI
REQUIREMENT_DEDUPLICATION_COLLECTION=TenderRequirementDeduplications
EVALUATION_CRITERIA_COLLECTION=EvaluationCriteria
TENDER_SECTION_PLAN_COLLECTION=TenderSectionPlans

LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=2
OPENAI_REASONING_EFFORT=medium

NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TIMEOUT_SECONDS=180
NVIDIA_MAX_RETRIES=2
NVIDIA_MAX_TOKENS=8192
NVIDIA_TEMPERATURE=1
NVIDIA_TOP_P=1
NVIDIA_ENABLE_THINKING=true
NVIDIA_CLEAR_THINKING=false

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_TIMEOUT_SECONDS=180
MISTRAL_MAX_RETRIES=2
MISTRAL_TEMPERATURE=0.2

SECTION_PLANNER_CONSTITUTION_PATH=Section_Planner_Constitution.md
SECTION_PLANNER_SPECIFICATION_PATH=Section_Planner_Specification.md
SECTION_PLANNER_USER_PROMPT_PATH=Section_Planner_User_Prompt.md

LLM_MAX_INPUT_TOKENS=12000
LLM_MAX_OUTPUT_TOKENS=3000
LLM_MAX_REPAIR_ATTEMPTS=1
